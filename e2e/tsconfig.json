{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": false,
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": [
      "node",
      "@playwright/test"
    ]
  },
  "include": [
    "playwright/**/*.ts",
    "playwright.config.ts"
  ]
}
